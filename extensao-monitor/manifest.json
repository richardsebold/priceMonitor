{
  "manifest_version": 3,
  "name": "Price Monitor - Add URL",
  "version": "1.2",
  "description": "Adiciona o produto da aba atual ao seu painel do Price Monitor (plano Hacker).",
  "permissions": ["activeTab", "cookies"],
  "host_permissions": [
    "https://price-monitor-smoky.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Monitorar este produto",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "icons": {
    "128": "icon.png"
  }
}
